typedef GenericUriParserOptions, gupo, circle-thin, circle, #0093F5, GenericUriParserOptions.%, Default|GenericAuthority|AllowEmptyAuthority|NoUserInfo|NoPort|NoQuery|NoFragment|DontConvertPathBackslashes|DontCompressPath|DontUnescapePathDotsAndSlashes|Idn|IriParsing;
typedef LoaderOptimization, lo, circle-thin, circle, #0093F5, LoaderOptimization.%, NotSpecified|SingleDomain|MultiDomain|DomainMask|MultiDomainHost|DisallowBindings;
typedef MidpointRounding, mpr, circle-thin, circle, #0093F5, MidpointRounding.%, ToEven|AwayFromZero|ToZero|ToNegativeInfinity|ToPositiveInfinity;
typedef PlatformID, pid, circle-thin, circle, #0093F5, PlatformID.%, Win32S|Win32Windows|Win32NT|WinCE|Unix|Xbox|MacOSX|Other;
typedef StringComparison, sc, circle-thin, circle, #0093F5, StringComparison.%, CurrentCulture|CurrentCultureIgnoreCase|InvariantCulture|InvariantCultureIgnoreCase|Ordinal|OrdinalIgnoreCase;
typedef StringSplitOptions, sso, circle-thin, circle, #0093F5, StringSplitOptions.%, None|RemoveEmptyEntries|TrimEntries;
typedef TypeCode, tc, circle-thin, circle, #0093F5, TypeCode.%, Empty|Object|DBNull|Boolean|Char|SByte|Byte|Int16|UInt16|Int32|UInt32|Int64|UInt64|Single|Double|Decimal|DateTime|String;
typedef UriComponents, uc, circle-thin, circle, #0093F5, UriComponents.%, SerializationInfoString|Scheme|UserInfo|Host|Port|SchemeAndServer|Path|Query|PathAndQuery|HttpRequestUrl|Fragment|AbsoluteUri|StrongPort|HostAndPort|StrongAuthority|NormalizedHost|KeepDelimiter;
typedef UriFormat, uf, circle-thin, circle, #0093F5, UriFormat.%, UriEscaped|Unescaped|SafeUnescaped;
typedef UriHostNameType, uhnt, circle-thin, circle, #0093F5, UriHostNameType.%, Unknown|Basic|Dns|IPv4|IPv6;


