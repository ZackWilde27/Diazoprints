string ToString(auto _x)
{
    x.ToString()
}

namespace Object
{
    bool equalsobj(Object objA, Object objB)
    {
        Object.Equals(objA, objB)
    } // Equals (Object)

    bool refequalsobj(Object objA, Object objB)
    {
        Object.ReferenceEquals(objA, objB);
    } // Reference Equals (Object)
};

namespace Version
{
    Version versionparse(string input)
    {
        Version.Parse(input)
    } // Parse (Version)

    bool TryParse(string input, Version out_result)
    {
        Version.TryParse(input, out_result)
    } // TryParse (Version)
};

namespace BitConverter
{
    byte[] GetBytes(auto value)
    {
        BitConverter.GetBytes(value)
    } // GetBytes (BitConverter)

    bool tobool(Array value)
    {
        BitConverter.ToBoolean(value)
    } // ToBoolean (BitConverter)

    char tochar(Array value)
    {
        BitConverter.ToChar(value)
    } // ToChar (BitConverter)

    double todouble(Array value)
    {
        BitConverter.ToDouble(value)
    } // ToDouble (BitConverter)

    Half tohalf(Array value)
    {
        BitConverter.ToHalf(value)
    } // ToHalf (BitConverter)
};