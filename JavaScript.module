Settings:
doc-link=https://www.w3schools.com/jsref/
separator=;\n
extension=js
var-fmt=%name
var-decl=let %name
var-sign=%name = %val
decl-sign=let %name = %val
param-separator=, 
param-decl=%name
param-format=%name
function-format=function %name(%inputs) {\n%code\n}\n
function-call=%name(%inputs)
struct-new=new %name(%params)
array-separator=, 
bools=true|false

Types:

// Name, Letter Code, Font Awesome 4 Icon for unconnected, Font Awesome 4 Icon for connected, Colour, Output, Input Tag Type
Boolean, b, circle-thin, circle, #FF0000, %, checkbox
Number, f, circle-thin, circle, #7CFC00, %, number
String, s, circle-thin, circle, #FF38D4, "%", text
Array, a, square-o, square, #0093F5, ,
RegExp, r, circle-thin, circle, #FFA21F, /%/, text
Function, fn, circle-thin, circle, #4800FF, %, 

// Types that are missing an input tag or output indicate that you can't create a constant, so it will be hidden in the commands menu
Int8Array, i8a, square-o, square, #457E58, %, 
Uint8Array, ui8a, square-o, square, #457E58, %, 
Uint8ClampedArray, ui8ca, square-o, square, #457E58, %, 
Int16Array, i16a, square-o, square, #457E58, %, 
Uint16Array, ui16a, square-o, square, #457E58, %, 
Int32Array, i32a, square-o, square, #457E58, %, 
Uint32Array, ui32a, square-o, square, #457E58, %, 
BigInt64Array, bi32a, square-o, square, #457E58, %, 
BigUint64Array, bui32a, square-o, square, #457E58, %, 
Float32Array, f32a, square-o, square, #7CFC00, %, 
Float64Array, f64a, square-o, square, #7CFC00, %, 

// Types with no icons will not show up in anything (commands menu, legend, or when selecting a type),
// it allows you to create a specific input for a specific situation, such as a dropdown menu for all the types of errors in JavaScript
Error Names, en, , , #FF0000, %, RangeError|ReferenceError|SyntaxError|TypeError|URIError

// Structs are structured like so:
// Name
// Colour
// Whether or not to create 'Break' and 'New' nodes
// [
//      property1_name, property1_type, property1_readwrite, property1_doc_link
// ]
// (
//      method1_name, method1_io, method1_link
// )
// documentation link

// readwrite is a string that determines whether a property can be written to or read from, or both.
// r means it can only be read, w means it can only be written to, and rw means you can do both

