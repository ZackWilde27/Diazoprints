        "If": {
            "type": "5",
            "format": "if (!False){ return \"if %1:\n%o0\n%c2\"; } if (!True){ return \"if not %1:\n%o1\n%c2\"; } return \"if %1:\n%o0\nelse:\n%o1\n%c2\";",
            "io": {
                "inputs": {
                    "": "exec",
                    "Condition": "bool"
                },
                "outputs": {
                    "True": "exec",
                    "False": "exec",
                    "Then": "exec"
                }
            },
            "link": "compound_stmts.html#the-if-statement"
        },
        "For": {
            "type": "1",
            "format": "for %n in %1:\n%o0\n%c2",
            "io": "e.;l.Array Like;o.;e.Loop;r.g.Item;e.Then;",
            "link": "compound_stmts.html#the-for-statement"
        },
        "For (Enumerate)": {
            "type": "1",
            "format": "for editor_reserved_index, editor_reserved_item in enumerate(%1):\n%o0\n%c3",
            "io": "e.;l.Array Like;o.;e.Loop;v.editor_reserved_item.g.Item;v.editor_reserved_index.i.Index;e.Then;",
            "link": ""
        },
        "For (Zip)": {
            "type": "1",
            "format": "for editor_reserved_item1, editor_reserved_item2 in zip(%1, %2):\n%o0\n%c3",
